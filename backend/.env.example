PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/amboras
# Comma-separated; include every dev UI origin (localhost vs 127.0.0.1, extra ports). Non-production also allows any localhost/127.0.0.1/::1 origin automatically.
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000
JWT_SECRET=dev-secret-change-me
REDIS_URL=redis://localhost:6379
ALLOW_INSECURE_DEV_TOKEN=false
# Set true behind HTTPS in production so auth cookies are only sent over TLS
COOKIE_SECURE=false
# IANA timezone for revenue "today" / week / month boundaries (calendar periods, not rolling 24h). Examples: UTC, America/New_York, Europe/London
ANALYTICS_TIMEZONE=UTC
