{
  "name": "amboras-analytics-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "lint": "tsc --noEmit",
    "test:funnel": "node scripts/verify-funnel-counts.mjs",
    "db:init": "node scripts/init-db.js",
    "db:seed": "node scripts/seed.js",
    "db:simulate-stream": "node scripts/simulate-stream.js",
    "db:simulate:store1": "cross-env STORE_ID=store_001 PURCHASES_PER_MINUTE=56 node scripts/simulate-stream.js",
    "db:simulate:store2": "cross-env STORE_ID=store_002 PURCHASES_PER_MINUTE=20 node scripts/simulate-stream.js",
    "db:simulate:store3": "cross-env STORE_ID=store_003 PURCHASES_PER_MINUTE=3.5 node scripts/simulate-stream.js"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.2",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.2",
    "@nestjs/platform-express": "^10.4.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.2"
  }
}
